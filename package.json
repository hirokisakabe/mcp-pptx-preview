{
  "name": "mcp-pptx-preview",
  "version": "0.1.0",
  "description": "MCP server that converts PPTX files to SVG previews",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcp-pptx-preview": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "pptx",
    "svg",
    "preview"
  ],
  "author": "hirokisakabe",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pptx-glimpse": "^0.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
